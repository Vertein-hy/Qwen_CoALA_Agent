# Local small model endpoint (forwarded from IPC via frp/stcp)
COALA_LOCAL_PROVIDER=openai_compat
COALA_LOCAL_MODEL=Qwen3.5-9B-Q4_K_M.gguf
COALA_LOCAL_API_BASE=http://127.0.0.1:18081/v1
COALA_LOCAL_API_KEY_ENV=COALA_LOCAL_API_KEY
COALA_LOCAL_REQUIRE_API_KEY=false
COALA_LOCAL_API_KEY=local-key
COALA_LOCAL_ASYNC_ENABLED=true
COALA_LOCAL_ASYNC_SUBMIT_PATH=/jobs
COALA_LOCAL_ASYNC_STATUS_PATH_TEMPLATE=/jobs/{job_id}
COALA_LOCAL_ASYNC_POLL_INTERVAL_S=1.0
COALA_LOCAL_ASYNC_TIMEOUT_S=600
COALA_LOCAL_MODEL_PROFILE=qwen3.5-9b
COALA_LOCAL_SUPPORTS_TOP_K=false
COALA_LOCAL_TIMEOUT_S=120
COALA_LOCAL_NUM_CTX=8192

# Keep most development traffic on the local model.
COALA_ROUTE_COMPLEXITY_THRESHOLD=999

# Optional remote large model (only used if routing selects large model)
COALA_REMOTE_MODEL=qwen3.5-397b-a17b
COALA_REMOTE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
COALA_REMOTE_API_KEY_ENV=QWEN_API_KEY
QWEN_API_KEY=

# Agent defaults
COALA_AGENT_TEMPERATURE=0.7
COALA_AGENT_TOP_P=0.8
COALA_AGENT_TOP_K=
COALA_AGENT_SEED=
COALA_AGENT_MAX_TOKENS=1024
COALA_AGENT_MAX_STEPS=5
COALA_AGENT_MEMORY_TOP_K=3
COALA_AGENT_RESPONSE_LANGUAGE=zh-CN
