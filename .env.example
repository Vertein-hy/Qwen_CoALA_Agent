# -----------------------------
# CoALA LLM configuration
# -----------------------------

# Local small model provider:
# - openai_compat (recommended, works with vLLM/SGLang)
# - vllm / sglang (aliases of openai_compat)
# - ollama (optional fallback)
COALA_LOCAL_PROVIDER=openai_compat

# Local small model identity and endpoint
COALA_LOCAL_MODEL=Qwen/Qwen3.5-9B-Instruct
COALA_LOCAL_API_BASE=http://127.0.0.1:8000/v1
COALA_LOCAL_API_KEY_ENV=COALA_LOCAL_API_KEY
COALA_LOCAL_REQUIRE_API_KEY=false
COALA_LOCAL_MODEL_PROFILE=qwen3.5-9b

# Optional: async local gateway mode (recommended when IPC<->model is over FRP)
COALA_LOCAL_ASYNC_ENABLED=false
COALA_LOCAL_ASYNC_SUBMIT_PATH=/jobs
COALA_LOCAL_ASYNC_STATUS_PATH_TEMPLATE=/jobs/{job_id}
COALA_LOCAL_ASYNC_POLL_INTERVAL_S=1.0
COALA_LOCAL_ASYNC_TIMEOUT_S=600

# If using llama.cpp + GGUF server, set:
# COALA_LOCAL_MODEL=qwen-local-gguf
# COALA_LOCAL_API_BASE=http://127.0.0.1:8000/v1

# If local endpoint supports top_k, set true (default false for compatibility)
COALA_LOCAL_SUPPORTS_TOP_K=false

# Only used when COALA_LOCAL_PROVIDER=ollama
COALA_OLLAMA_HOST=http://127.0.0.1:11434
COALA_LOCAL_NUM_CTX=8192

# Remote large model endpoint
COALA_REMOTE_MODEL=qwen3.5-397b-a17b
COALA_REMOTE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
COALA_REMOTE_API_KEY_ENV=QWEN_API_KEY

# Optional local key (some local servers ignore real auth and accept any key)
COALA_LOCAL_API_KEY=local-key

# -----------------------------
# CoALA generation defaults
# -----------------------------
COALA_AGENT_TEMPERATURE=0.7
COALA_AGENT_TOP_P=0.8
COALA_AGENT_RESPONSE_LANGUAGE=zh-CN

# Leave empty to disable that control
COALA_AGENT_TOP_K=
COALA_AGENT_SEED=

COALA_AGENT_MAX_TOKENS=1024

# Skill selection and telemetry
COALA_SKILL_CANDIDATE_TOP_K=3
COALA_SKILL_EVENT_LOG=true
COALA_SKILL_EVENT_LOG_DIR=data/logs/skill_events
